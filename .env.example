# DigitalOcean Gradient Inference (primary — get from DO Control Panel > Gradient AI > API Keys)
DO_INFERENCE_KEY=dop_v1_xxxxxxxxxxxxxxxxxxxx
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1
DO_MODEL=claude-sonnet-4-6
DO_KNOWLEDGE_BASE_ID=

# Database (auto-populated by DO App Platform from managed DB)
DATABASE_URL=postgresql://triageflow:triageflow@localhost:5432/triageflow

# LangSmith (optional — shows agent traces at smith.langchain.com)
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGSMITH_PROJECT=triageflow

# Local dev fallback only (used when DO_INFERENCE_KEY is empty)
ANTHROPIC_API_KEY=
ENVIRONMENT=development

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
